{
  "name": "FirstCAP",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@sap/cds": "^9",
    "@sap/cds-common-content": "^3.1.0",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "cds": {
    "requires": {
      "db": {
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "url": ":memory:"
          }
        },
        "[testing]": {
          "kind": "sqlite",
          "credentials": {
            "url": "db2.sqlite"
          }
        }
      }
    }
  },
  "private": true
}
